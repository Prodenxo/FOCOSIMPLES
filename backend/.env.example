# Copie para .env e preencha com valores reais. Nunca commite .env.
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,https://focosimples.com.br,https://focomei.com.br

# Auth: supabase (padrão) | local (Postgres EasyPanel, sem Supabase Auth)
# AUTH_MODE=local
# DATABASE_URL=postgres://postgres:SENHA@auto_focosimples-db:5432/focosimples?sslmode=disable
# AUTH_JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

SUPABASE_URL=
SUPABASE_ANON_KEY=
# Settings → JWT Keys → aba "Legacy JWT Secret" (string longa; não é anon key nem UUID de signing key)
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: Postgres direto (db.<ref>.supabase.co) para scripts de migration
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
FRONTEND_URL=http://localhost:8081
# focosimples | focomei
APP_PRODUCT=focosimples
# AES-256 — 32 bytes em base64 (obrigatório para persistir certificado A1 entre reinícios do backend)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MEI_CERT_ENCRYPTION_KEY=

# --- Integra Contador (SERPRO) — DAS MEI (PGMEI) e DAS Simples (PGDASD) ---
# Contratar na Loja SERPRO o produto Integra Contador com módulo Integra SN / PGDASD.
# Spike: node scripts/one-time/spike-pgdasd.mjs <CNPJ14> [AAAAMM]
# SERPRO_API_BASE_URL=https://gateway.apiserpro.serpro.gov.br/integra-contador/v1
# SERPRO_OAUTH_TOKEN_URL=
# SERPRO_CONSUMER_KEY=
# SERPRO_CONSUMER_SECRET=
# SERPRO_CERT_PFX_BASE64=
# SERPRO_CONTRATANTE_NUMERO=
# SERPRO_CONTRATANTE_NOME=
# URL base do app FocoSimples (convites / OAuth)
# INVITE_APP_BASE_URL=https://focosimples.com.br
# Limite p or IP/minuto nas rotas públicas GET|POST /api/invites/validate (padrão 120 em dev).
# INVITE_VALIDATE_MAX_PER_MINUTE=120
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# FR-GUIA-FISC-16 (opcional) — `false` faz `emitir` devolver 403 para NFE/NFC-e; omitir = sem bloqueio extra (paridade com UI sem flag).
# MEI_NFE_NFCE_EMIT_ENABLED=false
#
# --- Plugnotas (cadastro empresa + emissão NFSe/NFe/NFCe) ---
# Doc API: https://docs.plugnotas.com.br/ | Primeiros passos TecnoSpeed: https://atendimento.tecnospeed.com.br/hc/pt-br/articles/23715383551767-Primeiros-Passos-com-o-Plugnotas
#
# Produção (API oficial — mesmo host para emissão real e homologação na prefeitura/SEFAZ):
#   PLUGNOTAS_API_BASE_URL=https://api.plugnotas.com.br
#   PLUGNOTAS_API_KEY=<token no Plugnotas: avatar → "Exibir token" — não use o token genérico só do TecnoAccount>
# Homologação vs produção no JSON da nota/empresa: campo config.producao (true/false); NÃO troque a URL base por isso.
#
# Sandbox (mock, token e host próprios): ver docs por operação — ex. base https://api.sandbox.plugnotas.com.br
# Regra: base + x-api-key sempre do MESMO ambiente (não misture produção com token de sandbox).
#
# Deploy: replique PLUGNOTAS_* no backend (Vercel etc.); inclua Preview se testar PRs, senão só Production.
# CORS: CORS_ORIGIN e FRONTEND_URL devem incluir a origem do site que chama a API.
#
# Guia MEI / cadastro empresa apenas NFS-e: normalização em código (nfe/nfce inativos, IE vazia → ISENTO).
# Ver docs/adr/ADR-plugnotas-empresa-payload-apenas-nfse.md
#
# Trilho B (FR-PREFB / P0): com `true`, o BFF deriva `nfse.config.prefeitura.codigoIbge` a partir de
# `endereco.codigoCidade` já normalizado (7 dígitos IBGE). Desligado por defeito (omitir ou `false`).
# Reinicie o processo Node após alterar esta env. Dev/staging: ok para testes; produção opt-in —
# ver NFR-PREF-EV-01 e docs/operacao-mei-nfse.md#prefb-trilho-b-env-derive-ibge (brief §3 alinha ordem diagnóstico).
# PLUGNOTAS_NFSE_PREFEITURA_DERIVE_IBGE=true
#
# DP-PLOGIN-01 — credenciais do portal municipal em `nfse.config.prefeitura` (login/senha). Omitir ou `false` até decisão PO.
# O frontend usa `VITE_PLUGNOTAS_NFSE_PREFEITURA_CREDENCIAIS_ENABLED` alinhado a esta flag.
# PLUGNOTAS_NFSE_PREFEITURA_CREDENCIAIS_ENABLED=true
#
# DP-PLOGIN-02 — bloqueio cedo quando só `codigoIbge` em prefeitura e o município está na lista (emissores que exigem dados extra).
# Omitir ou `false` por defeito. Lista vazia ⇒ nunca bloqueia. Reinicie o Node após alterar.
# PLUGNOTAS_NFSE_PREFEITURA_IBGE_ONLY_BLOCK_ENABLED=true
# PLUGNOTAS_NFSE_PREFEITURA_IBGE_ONLY_BLOCK_CODES=3550308,3304557
PLUGNOTAS_API_BASE_URL=
# Opcional: prefixo antes de /empresa, /nfse, etc. (ex.: /api) — só se a doc da conta exigir; docs públicas usam paths na raiz do host
PLUGNOTAS_API_PATH_PREFIX=
PLUGNOTAS_API_KEY=
# Opt-in explícito em produção: mais logs [plugnotas] e, com HTTP 400 em POST/PATCH /empresa, linha
# [plugnotas empresa cadastro] … payload (redacted). Fora de produção esse payload já pode logar sem a flag.
# PLUGNOTAS_DEBUG=true
# Após POST /certificado 409, logs estruturados da cadeia GET (empresa → certificado filtro → listagem): off | error | warn | info | debug (padrão warn)
# PLUGNOTAS_CERT_409_RESOLVE_LOG_LEVEL=warn
# Desliga o log estruturado FR-TIBGE-OBS-01 (400 IBGE/tabela) se o volume incomodar: off | false | 0
# PLUGNOTAS_EMPRESA_IBGE_TABLE_LOG=off
# Nível de log para HTTP 400 em emissão (requestJson): error (padrão) ou warn
# PLUGNOTAS_EMIT_400_LOG_LEVEL=error
PLUGNOTAS_TIMEOUT_MS=15000
PLUGNOTAS_WEBHOOK_TOKEN=
PLUGNOTAS_WEBHOOK_REQUIRE_TOKEN=true
PLUGNOTAS_WEBHOOK_ALLOW_QUERY_TOKEN=false

# Opcional: automação (OpenClaw/n8n). Com Bearer igual a este valor em GET /api/* é obrigatório header X-MeuFinanceiro-User-Id ou query userId (UUID Supabase).
# API_SECRET=
# Segundo segredo opcional (mesmo contrato que API_SECRET). Útil se API_SECRET já estiver reservado a outra integração.
# API_SECRET_OP=

# --- Bot OpenClaw / n8n — POST /api/bot/openclaw/action ---
# OPENCLAW_WEBHOOK_SECRET=
# URL completa para `npm run test:openclaw:salario` contra staging/prod (senão localhost:PORT).
# OPENCLAW_ACTION_URL=https://teu-backend.easypanel.host/api/bot/openclaw/action
# Categoria no teste de salário (opcional, padrão Salário).
# TEST_OPENCLAW_CLASSIFICACAO=Salário
# Teste local NFSe (scripts/test-openclaw-nfse.mjs):
# TEST_NFSE_TOMADOR_CNPJ=00000000000000
# TEST_NFSE_TOMADOR_NOME=Cliente teste
# TEST_NFSE_VALOR=1200
# TEST_NFSE_DESCRICAO=consultoria
# TEST_NFSE_CODIGO_SERVICO=010701
# TEST_NFSE_CNAE=6201500
# Teste local NFSe (scripts/test-openclaw-nfse.mjs):
# TEST_NFSE_TOMADOR_CNPJ=00000000000000
# TEST_NFSE_TOMADOR_NOME=Cliente teste
# TEST_NFSE_VALOR=1200
# TEST_NFSE_DESCRICAO=consultoria
# TEST_NFSE_CODIGO_SERVICO=010701
# TEST_NFSE_CNAE=6201500

# --- Webhook Z-API → relay opcional (OpenClaw / n8n) — POST /api/webhooks/zapi/inbound?token=... ---
# ZAPI_WEBHOOK_TOKEN=
# OPENCLAW_ZAPI_RELAY_URL=https://teu-n8n/webhook/zapi-openclaw
# OPENCLAW_ZAPI_RELAY_SECRET=
# OPENCLAW_ZAPI_RELAY_TIMEOUT_MS=8000
# Notas de voz Z-API: transcrição antes do relay (OpenAI ou Groq). Ver docs/ops/openclaw-audio-transcricao.md
# WHATSAPP_AUDIO_TRANSCRIPTION_ENABLED=true
# OPENAI_API_KEY=
# GROQ_API_KEY=
# WHATSAPP_TRANSCRIPTION_OPENAI_API_KEY=

# --- WhatsApp saída (DAS, agenda, admin) — Z-API directo (recomendado; dispensa n8n) ---
# WHATSAPP_OUTBOUND_MODE=auto
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=
# ZAPI_API_BASE_URL=https://api.z-api.io
# Legado (enquanto migra): N8N_WHATSAPP_WEBHOOK_URL=
# N8N_WHATSAPP_WEBHOOK_SECRET=
# MEI_DAS_AUTO_WHATSAPP_ENABLED=false
# AGENDA_WHATSAPP_REMINDERS_ENABLED=false
# Solicitação de acesso: WhatsApp a TODOS os superadmins (telefone em n8n_link/perfil) + solicitante ao aprovar
# ACCESS_REQUEST_WHATSAPP_NOTIFY_ENABLED=false
# ACCESS_REQUEST_NOTIFY_SUPERADMIN_EXTRA_PHONES=5521999999999,5521988887777
# CRON_SECRET=
