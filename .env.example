# FocoSimples — frontend (raiz do repo)
# Copie para `.env` e reinicie o Expo com cache limpo: npx expo start -c

EXPO_PUBLIC_AUTH_MODE=local
EXPO_PUBLIC_APP_PRODUCT=focosimples

# API backend (dev local)
EXPO_PUBLIC_MEI_API_URL_DEV=http://localhost:3333

# Em produção / EasyPanel (URL pública do backend)
# EXPO_PUBLIC_MEI_API_URL=https://SEU-BACKEND.easypanel.host
# EXPO_PUBLIC_INVITE_APP_BASE_URL=https://focosimples.com.br

# NÃO precisa de Supabase com AUTH_MODE=local
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
